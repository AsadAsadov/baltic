generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id              String   @id @default(uuid()) @db.Uuid
  legacyId        Int?     @unique @map("legacy_id")
  slug            String   @unique
  category        String   @default("house") @map("category")
  categoryNameAz  String?  @map("category_name_az")
  categoryNameRu  String?  @map("category_name_ru")
  categoryNameEn  String?  @map("category_name_en")
  titleAz         String   @map("title_az")
  titleRu         String?  @map("title_ru")
  titleEn         String?  @map("title_en")
  descriptionAz   String?  @map("description_az")
  descriptionRu   String?  @map("description_ru")
  descriptionEn   String?  @map("description_en")
  area            String?  @default("0")
  stories         Int      @default(1)
  rooms           Int      @default(1)
  buildTimeAz     String?  @map("build_time_az")
  buildTimeRu     String?  @map("build_time_ru")
  buildTimeEn     String?  @map("build_time_en")
  coverImage      String?  @map("cover_image")
  images          Json?    @default("[]")
  views           Int      @default(0)
  archived        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model GalleryItem {
  id        Int      @id @default(autoincrement())
  mediaUrl  String   @map("media_url")
  images    Json?    @default("[]")
  titleAz   String   @map("title_az")
  titleRu   String?  @map("title_ru")
  titleEn   String?  @map("title_en")
  type      String   @default("image")
  sortOrder Int      @default(0) @map("sort_order")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gallery_items")
}

model HeroSlide {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legacyId     Int?     @unique @map("legacy_id")
  titleAz      String?  @map("title_az")
  titleRu      String?  @map("title_ru")
  titleEn      String?  @map("title_en")
  subtitleAz   String?  @map("subtitle_az")
  subtitleRu   String?  @map("subtitle_ru")
  subtitleEn   String?  @map("subtitle_en")
  mediaType    String   @default("image") @map("media_type")
  mediaUrl     String   @map("media_url")
  image        String?
  buttonTextAz String?  @map("button_text_az")
  buttonTextRu String?  @map("button_text_ru")
  buttonTextEn String?  @map("button_text_en")
  buttonLink   String?  @map("button_link")
  tagAz        String?  @map("tag_az")
  tagRu        String?  @map("tag_ru")
  tagEn        String?  @map("tag_en")
  title1Az     String?  @map("title1_az")
  title1Ru     String?  @map("title1_ru")
  title1En     String?  @map("title1_en")
  title2Az     String?  @map("title2_az")
  title2Ru     String?  @map("title2_ru")
  title2En     String?  @map("title2_en")
  descAz       String?  @map("desc_az")
  descRu       String?  @map("desc_ru")
  descEn       String?  @map("desc_en")
  sortOrder    Int      @default(0) @map("sort_order")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("hero_slides")
}

model Banner {
  id            String   @id @default(uuid()) @db.Uuid
  legacyId      Int?     @unique @map("legacy_id")
  active        Boolean  @default(true)
  mediaType     String   @default("image") @map("media_type")
  mediaUrl      String?  @map("media_url")
  linkUrl       String?  @map("link_url")
  title         String?
  titleAz       String?  @map("title_az")
  titleRu       String?  @map("title_ru")
  titleEn       String?  @map("title_en")
  descriptionAz String?  @map("description_az")
  descriptionRu String?  @map("description_ru")
  descriptionEn String?  @map("description_en")
  type          String?
  width         Int      @default(260)
  height        Int      @default(600)
  duration      Int      @default(15)
  displayOrder  Int      @default(0) @map("display_order")
  views         Int      @default(0)
  clicks        Int      @default(0)
  placement     String   @default("both")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  legacyId  Int?     @unique @map("legacy_id")
  name      String?
  fullname  String?
  phone     String?
  email     String?
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("contact_messages")
}

model HomeSectionImage {
  id         String   @id @default(uuid()) @db.Uuid
  sectionKey String   @map("section_key")
  title      String?
  imageUrl   String   @map("image_url")
  sortOrder  Int      @default(0) @map("sort_order")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("home_section_images")
}

model SiteStat {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_stats")
}

model StatEvent {
  id        Int      @id @default(autoincrement())
  type      String
  targetId  Int?     @map("target_id")
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("stat_events")
}

model AdminPanelSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_panel_settings")
}

model WorkItem {
  id             String    @id @default(uuid()) @db.Uuid
  slug           String    @unique
  category       String
  titleAz        String    @map("title_az")
  titleRu        String?   @map("title_ru")
  titleEn        String?   @map("title_en")
  descriptionAz  String?   @map("description_az")
  descriptionRu  String?   @map("description_ru")
  descriptionEn  String?   @map("description_en")
  locationAz     String?   @map("location_az")
  locationRu     String?   @map("location_ru")
  locationEn     String?   @map("location_en")
  completionDate DateTime? @map("completion_date")
  coverImage     String    @map("cover_image")
  images         Json?     @default("[]")
  sortOrder      Int       @default(0) @map("sort_order")
  featured       Boolean   @default(false)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("work_items")
}
